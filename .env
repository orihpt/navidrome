ND_CONFIGFILE=navidrome.toml
# You can also set other variables here, e.g.
# ND_LOGLEVEL=debug

# Offline-first defaults. These keep Navidrome from contacting Deezer,
# Last.fm, ListenBrainz, or the Navidrome insights collector.
ND_ENABLEEXTERNALSERVICES=false
ND_ENABLEINSIGHTSCOLLECTOR=false
ND_AGENTS=

# Local app database used by the Waves Music stack during development.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=waves_music

# Admin user
ENABLE_ADMIN_USER_STATIC_PASSWORD=true
ADMIN_USER_STATIC_PASSWORD=0hN0L3aked123

# Music Folder
ND_MUSICFOLDER=/Users/orihpt2/Music