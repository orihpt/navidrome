ND_CONFIGFILE=navidrome.toml
# You can also set other variables here, e.g.
# ND_LOGLEVEL=debug

# Offline-first defaults. These keep Navidrome from contacting Deezer,
# Last.fm, ListenBrainz, or the Navidrome insights collector.
ND_ENABLEEXTERNALSERVICES=false
ND_ENABLEINSIGHTSCOLLECTOR=false
ND_AGENTS=
